const order = { items: [], total: 0 };

function showOrder() {
  console.log("\nCurrent order:");
  order.items.forEach((item,i)=>console.log(`${i+1}. ${item.type} - ${item.name}${item.size?` (${item.size})`:''} - ${item.price}€`));
  console.log(`Total: ${order.total}€\n`);
}

function calculateTotal() {
  order.total = order.items.reduce((sum,i)=>sum+i.price,0);
}

function addPizza(name, size) {
  if(!pizza_max_vapi_menu.named_pizzas[name] || !pizza_max_vapi_menu.named_pizzas[name][size]) {
    console.log("Invalid pizza or size");
    return;
  }
  const price = pizza_max_vapi_menu.named_pizzas[name][size];
  order.items.push({ type: "pizza", name, size, price });
  calculateTotal();
}

function addItem(type, name) {
  if(!pizza_max_vapi_menu.categories[type] || pizza_max_vapi_menu.categories[type][name] === undefined) {
    console.log("Invalid item");
    return;
  }
  const price = pizza_max_vapi_menu.categories[type][name];
  order.items.push({ type, name, price });
  calculateTotal();
}

function askQuestion(question) {
  return new Promise(resolve => rl.question(question, ans => resolve(ans.trim())));
}

async function orderFlow() {
  while(true) {
    const type = await askQuestion("Order type (pizza/chips/sides1/sides_2/drinks/milkshakes/burgers/spicy_bags/deals) or 'done' to finish: ");
    if(type.toLowerCase() === "done") break;

    if(type==="pizza") {
      const name = await askQuestion(`Choose pizza (${Object.keys(pizza_max_vapi_menu.named_pizzas).join(", ")}): `);
      const size = await askQuestion(`Choose size (${Object.keys(pizza_max_vapi_menu.sizes).join(", ")}): `);
      addPizza(name, size);
    } else {
      const name = await askQuestion(`Choose ${type} (${Object.keys(pizza_max_vapi_menu.categories[type]).join(", ")}): `);
      addItem(type, name);
    }

    showOrder();

    let confirmOrder = await askQuestion("Confirm order? (yes/no/correct): ");
    if(confirmOrder.toLowerCase() === "yes") break;
    else if(confirmOrder.toLowerCase() === "correct") {
      let action = await askQuestion("Remove or replace an item? (remove/replace): ");
      showOrder();
      if(action==="remove") {
        let idx = parseInt(await askQuestion("Enter item number to remove: "));
        if(idx>0 && idx<=order.items.length) order.items.splice(idx-1,1);
      } else if(action==="replace") {
        let idx = parseInt(await askQuestion("Enter item number to replace: "));
        if(idx>0 && idx<=order.items.length) order.items.splice(idx-1,1);
      }
      calculateTotal();
      showOrder();
    }
  }
  console.log("\nFinal order confirmed:");
  showOrder();
  rl.close();
}

orderFlow();